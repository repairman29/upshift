{
  "name": "upshift-cli",
  "version": "0.4.3",
  "description": "AI-powered dependency upgrades with explanations and safe rollbacks.",
  "type": "module",
  "bin": {
    "upshift": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/repairman29/upshift.git"
  },
  "homepage": "https://upshiftai.dev",
  "keywords": [
    "dependencies",
    "upgrade",
    "security",
    "vulnerabilities",
    "npm",
    "yarn",
    "pnpm",
    "cli",
    "ai"
  ],
  "author": "Jeff Adkins",
  "scripts": {
    "build": "tsup src/cli.ts src/server.ts --format esm --dts --clean",
    "dev": "node --loader ts-node/esm src/cli.ts",
    "start": "node dist/cli.js",
    "server": "node dist/server.js",
    "test": "npm run e2e:all",
    "e2e": "npm run build && node tests/e2e/cli.e2e.mjs",
    "verify-site": "node scripts/verify-site.mjs",
    "verify-site:live": "node scripts/verify-site.mjs --live",
    "github-app-checklist": "node scripts/github-app-checklist.mjs",
    "supabase:push": "supabase db push --linked",
    "supabase:push:dry": "supabase db push --linked --dry-run",
    "supabase:inspect": "supabase inspect db traffic-profile --linked",
    "supabase:deploy": "supabase db push --linked && supabase functions deploy",
    "dogfood": "npm run build && node dist/cli.js scan",
    "dogfood:upgrade": "node dist/cli.js upgrade",
    "e2e:browser": "playwright test",
    "e2e:all": "npm run e2e && npm run verify-site && npm run e2e:browser",
    "serve:web": "serve web -p 3333"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "chalk": "^5.3.0",
    "chalk-animation": "^2.0.3",
    "commander": "^14.0.3",
    "diff": "^8.0.3",
    "express": "^5.2.1",
    "glob": "^13.0.6",
    "inquirer": "^13.3.0",
    "openai": "^6.25.0",
    "ora": "^9.3.0",
    "resend": "^6.9.2",
    "semver": "^7.7.4",
    "stripe": "^20.4.0",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.2",
    "@types/semver": "^7.7.1",
    "serve": "^14.2.5",
    "supabase": "^2.76.15",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "files": [
    "dist",
    "migrations"
  ]
}
